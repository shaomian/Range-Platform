# Backend configuration. Copy to .env and adjust as needed.

# JWT secret. CHANGE THIS in production.
SECRET_KEY=change-me-to-a-random-secret-string
ACCESS_TOKEN_EXPIRE_MINUTES=720

# SQLite database URL
DATABASE_URL=sqlite:///./range_platform.db

# Absolute or relative path to the vulhub directory
VULHUB_ROOT=../../vulhub

# Host used to build accessible URLs shown to users
SERVER_HOST=localhost

# Initial admin account created on first startup
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Max concurrent running instances per normal user
MAX_INSTANCES_PER_USER=3

# Instance auto-stop TTL (minutes). Seeded into the DB on first startup;
# afterwards admin-tunable from the System Settings page (no restart needed).
INSTANCE_DEFAULT_TTL_MINUTES=60
# Max renewal duration (minutes) for non-admin users. Seeded into the DB on
# first startup; afterwards admin-tunable from the System Settings page.
INSTANCE_MAX_TTL_MINUTES=1440

# Comma separated list of allowed CORS origins for the frontend
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
